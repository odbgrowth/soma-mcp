# SOMA MCP configuration. Copy to .env and fill in.
# Without the AUTH0_* block the server runs UNAUTHENTICATED (local use only).

# --- OAuth 2.1 (Auth0) ---
AUTH0_CONFIG_URL=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=
BASE_URL=https://your-host.example/

# --- Access control (fail-closed) ---
# Comma-separated token subjects allowed to use this instance.
MCP_TOEGANG_SUBJECTS=
# Subset allowed to write (soma_write / soma_update / soma_delete).
MCP_SCHRIJF_SUBJECTS=
# Set to 1 to run deliberately without an allowlist (single-user).
MCP_SINGLE_USER=
# Calls per minute per subject (default 30; 0 disables).
MCP_RATE_LIMIT=30

# --- Persistent, encrypted token storage (optional; needs .[auth]) ---
MCP_JWT_SIGNING_KEY=
MCP_STORAGE_ENCRYPTION_KEY=

# --- Data path (token store + audit log) ---
SOMA_DATA=.
